---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ResourceCard from "../components/ResourceCard.astro";
import Newsletter from "../components/Newsletter.astro";
import { topics } from "../data/topics";

const resources = (await getCollection("resources")).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf()
);

const featured = resources
  .filter((resource) => resource.data.featured)
  .slice(0, 3);

const recent = resources
  .filter(
    (resource) =>
      resource.data.resourceType !== "book" &&
      !resource.data.featured
  )
  .sort(
    (a, b) =>
      b.data.publishedDate.getTime() -
      a.data.publishedDate.getTime()
  )
  .slice(0, 6);

const books = resources
  .filter((resource) => resource.data.resourceType === "book")
  .slice(0, 6);
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">
          <span></span>
          Thoughtfully curated
        </span>

        <h1>
          Learn better
          <span class="gradient-text">SwiftUI architecture.</span>
        </h1>

        <p>
          Discover thoughtfully selected articles, videos, books, talks, and
          open-source projects from across the Swift community.
        </p>

        <div class="hero-actions">
          <a class="button button-primary" href="/resources/">
            Explore Resources
          </a>

          <a class="button button-secondary" href="/topics/">
            Browse Topics
          </a>
        </div>

        <div class="hero-stats">
          <div>
            <strong>{resources.length}</strong>
            <span>Curated resources</span>
          </div>

          <div>
            <strong>{topics.length}</strong>
            <span>Architecture topics</span>
          </div>

          <div>
            <strong>
              {new Set(resources.map((resource) => resource.data.author)).size}
            </strong>
            <span>Creators</span>
          </div>
        </div>
      </div>

      <aside class="featured-panel">
        <div class="panel-header">
          <div>
            <span class="panel-eyebrow">Curated by the editor</span>
            <h2>Featured resources</h2>
          </div>

          <a class="view-all-link" href="/resources/">
            View all
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="featured-stack">
          {
            featured.map((resource, index) => {
              const isPrimary = index === 0;
              const isLiveEvent =
                resource.data.resourceType === "live-event";

              return (
                <a
                  class:list={[
                    "featured-item",
                    {
                      primary: isPrimary,
                      "live-event": isLiveEvent
                    }
                  ]}
                  href={resource.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <div class="featured-meta">
                    <span class="resource-type">
                      {isLiveEvent
                        ? "Live Event"
                        : resource.data.resourceType.replace("-", " ")}
                    </span>

                    {isPrimary && (
                      <span class="featured-badge">
                        Editor’s pick
                      </span>
                    )}
                  </div>

                  <h3>{resource.data.title}</h3>

                  {isPrimary && resource.data.summary && (
                    <p class="featured-summary">
                      {resource.data.summary}
                    </p>
                  )}

                  <div class="featured-footer">
                    <span>
                      {resource.data.author}

                      {resource.data.difficulty && (
                        <> · {resource.data.difficulty}</>
                      )}
                    </span>

                    <span class="featured-arrow" aria-hidden="true">
                      →
                    </span>
                  </div>
                </a>
              );
            })
          }
        </div>
      </aside>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <div class="section-heading">
        <div>
          <span class="section-kicker">New additions</span>
          <h2>Recently curated</h2>
          <p>
            Useful resources selected for clarity and practical relevance.
          </p>
        </div>

        <a class="section-link" href="/resources/">
          Browse the library →
        </a>
      </div>

      <div class="resource-grid">
        {recent.map((resource) => (
          <ResourceCard resource={resource} />
        ))}
      </div>
    </div>
  </section>

  <section class="section editor-section">
    <div class="container">
      <div class="editor-note">
        <div class="editor-note-accent" aria-hidden="true"></div>

      
      </div>
    </div>
  </section>

  {books.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-heading">
          <div>
            <span class="section-kicker">Books</span>
            <h2>Essential SwiftUI architecture books</h2>

            <p>
              Carefully selected books covering architecture, state management,
              data flow, persistence, and application design.
            </p>
          </div>

          <a class="section-link" href="/resources/?type=book">
            View all books →
          </a>
        </div>

        <div class="resource-grid">
          {books.map((book) => (
            <ResourceCard resource={book} />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container community-callout">
      <div>
        <span class="section-kicker light">Community</span>
        <h2>Published something useful?</h2>

        <p>
          Submit an article, video, conference talk, book, or open-source
          project for consideration.
        </p>
      </div>

      <a class="button button-light" href="/submit/">
        Submit a Resource
      </a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <Newsletter />
    </div>
  </section>
</BaseLayout>

<style>
  .editor-section {
    padding-top: 0;
  }

  .editor-note {
    position: relative;
    display: grid;
    grid-template-columns: 5px minmax(0, 1fr);
    overflow: hidden;
    max-width: 960px;
    margin-inline: auto;
    border: 1px solid rgba(79, 70, 229, 0.16);
    border-radius: 24px;
    background:
      radial-gradient(
        circle at top right,
        rgba(124, 58, 237, 0.1),
        transparent 42%
      ),
      #ffffff;
    box-shadow:
      0 20px 50px rgba(15, 23, 42, 0.07),
      0 2px 8px rgba(15, 23, 42, 0.04);
  }

  .editor-note-accent {
    background: linear-gradient(
      180deg,
      #7c3aed,
      #2563eb
    );
  }

  .editor-note-content {
    padding: clamp(2rem, 5vw, 3.5rem);
  }

  .editor-note h2 {
    margin: 0.45rem 0 1.25rem;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    letter-spacing: -0.04em;
  }

  .editor-note p {
    max-width: 720px;
    margin: 0 0 1rem;
    color: var(--color-text-muted, #475569);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .editor-signature {
    display: flex;
    flex-direction: column;
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(15, 23, 42, 0.08);
  }

  .editor-signature strong {
    color: var(--color-text, #0f172a);
    font-size: 1rem;
  }

  .editor-signature span {
    margin-top: 0.2rem;
    color: var(--color-text-muted, #64748b);
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .editor-note {
      grid-template-columns: 4px minmax(0, 1fr);
      border-radius: 18px;
    }

    .editor-note-content {
      padding: 1.75rem 1.5rem;
    }

    .editor-note p {
      font-size: 1rem;
      line-height: 1.7;
    }
  }
</style>