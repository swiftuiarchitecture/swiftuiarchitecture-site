---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Submission Received"
  description="Thank you for submitting a resource."
>
  <section class="page-hero compact">
    <div class="container narrow">
      <span class="eyebrow"><span></span> Thank you</span>

      <h1>Submission received!</h1>

      <p>
        Thank you for helping grow the SwiftUI Architecture resource library.
        I'll review your submission and add it if it's a good fit for the site.
      </p>

      <p>
        <a class="button button-primary" href="/">
          Return Home
        </a>
      </p>
    </div>
  </section>
</BaseLayout>