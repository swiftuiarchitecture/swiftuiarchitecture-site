---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Submit a Resource"
  description="Submit a SwiftUI architecture resource for consideration."
>
  <section class="page-hero compact">
    <div class="container narrow">
      <span class="eyebrow"><span></span> Community submissions</span>

      <h1>Submit a Resource</h1>

      <p>
        Share an article, video, book, conference talk, podcast, WWDC session,
        or open source project related to SwiftUI architecture.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container form-layout">

      <form
        class="submission-form"
        action="https://formsubmit.co/azamsharp@gmail.com"
        method="POST"
      >

        <!-- Email subject -->
        <input
          type="hidden"
          name="_subject"
          value="New SwiftUI Architecture Resource Submission"
        />

        <!-- Redirect after successful submission -->
        <input
          type="hidden"
          name="_next"
          value="https://swiftuiarchitecture.com/submission-success/"
        />

        <!-- Nicely formatted email -->
        <input
          type="hidden"
          name="_template"
          value="table"
        />

        <!-- Enable CAPTCHA -->
        <input
          type="hidden"
          name="_captcha"
          value="true"
        />

        <!-- Honeypot spam trap -->
        <input
          type="text"
          name="_honey"
          class="honeypot"
          tabindex="-1"
          autocomplete="off"
        />

        <div class="field">
          <label for="title">Resource title</label>
          <input
            id="title"
            name="title"
            type="text"
            required
          />
        </div>

        <div class="field">
          <label for="url">Resource URL</label>
          <input
            id="url"
            name="url"
            type="url"
            placeholder="https://"
            required
          />
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="author">Author or creator</label>
            <input
              id="author"
              name="author"
              type="text"
              required
            />
          </div>

          <div class="field">
            <label for="type">Resource type</label>

            <select
              id="type"
              name="type"
              required
            >
              <option value="">Select a resource type</option>
              <option>Article</option>
              <option>Video</option>
              <option>Book</option>
              <option>Conference Talk</option>
              <option>WWDC Session</option>
              <option>Podcast</option>
              <option>Open Source Project</option>
            </select>
          </div>
        </div>

        <div class="field-grid">
          <div class="field">
            <label for="submitterName">Your name</label>
            <input
              id="submitterName"
              name="submitterName"
              type="text"
              required
            />
          </div>

          <div class="field">
            <label for="email">Your email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
            />
          </div>
        </div>

        <div class="field">
          <label for="reason">
            Why should this resource be included?
          </label>

          <textarea
            id="reason"
            name="reason"
            rows="6"
            placeholder="Tell us why this resource would benefit the SwiftUI Architecture community."
            required
          ></textarea>
        </div>

        <button
          class="button button-primary"
          type="submit"
        >
          Submit Resource
        </button>

      </form>

      <aside class="submission-note">
        <h2>Submission Guidelines</h2>

        <p>
          Please submit links to the original publisher or creator.
        </p>

        <p>
          Every submission is reviewed before it is added to the library.
          Quality, accuracy, and relevance to SwiftUI architecture are the
          primary selection criteria.
        </p>

        <p>
          We appreciate every submission, but inclusion is not guaranteed.
        </p>
      </aside>

    </div>
  </section>
</BaseLayout>

<style>
.honeypot {
  display: none;
}
</style>